# =============================================================================
# .gitignore - Analisis Sentimen Sumatera Blackout
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual Environment
venv/
env/
.env/

# Jupyter Notebook
.ipynb_checkpoints/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/*.log

# Models (large files)
models/*.pkl
models/*.h5
models/*.joblib

# Data (uncomment if dataset is too large for git)
# data/raw/*.csv
# data/raw/*.xlsx
# data/processed/*.csv
